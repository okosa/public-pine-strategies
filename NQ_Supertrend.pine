//@version=6
strategy("NQ Supertrend", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=15)

atrPeriod = input.int(10, "ATR Length", minval=1)
factor    = input.float(3.0, "Factor", step=0.01)

[st, direction] = ta.supertrend(factor, atrPeriod)

bullFlip = ta.change(direction) < 0
bearFlip = ta.change(direction) > 0
bull     = direction < 0
bear     = direction > 0

if bullFlip
    strategy.entry("Long", strategy.long)

if bearFlip
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0 and bear
    strategy.close("Long")

if strategy.position_size < 0 and bull
    strategy.close("Short")

plot(st, "Supertrend", color=bull ? color.green : color.red, linewidth=2)
